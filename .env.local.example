# ─────────────────────────────────────────────────────────────────────────────
# Fundfi Customer Portal — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# NestJS API base URL (no trailing slash)
# Mock mode: leave empty — services use local mock data instead
NEXT_PUBLIC_API_URL=

# App URL (used for absolute links in emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Production only ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.fundfi.com/api/v1
# NEXT_PUBLIC_APP_URL=https://portal.fundfi.com
